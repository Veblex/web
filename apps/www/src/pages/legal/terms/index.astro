---
import Layout from "@layouts/root.astro";
---

<Layout page="Terms of Service" description="The terms governing your use of Veblex services and the Veblex ecosystem.">
    <main class="flex-1">
        <article
            class="mx-auto container max-w-2xl px-4 sm:px-6 lg:px-8 py-16"
        >
            <section>
                <a
                    href="/legal"
                    class="text-muted-foreground font-mono uppercase underline-offset-2 transition-all duration-300 hover:underline"
                >
                    Legal
                </a>
                <h1 class="my-4 text-4xl font-bold tracking-tight sm:text-4xl">
                    Terms of Service
                </h1>
                <p class="text-lg text-muted-foreground">
                    The terms governing your use of the Veblex ecosystem.
                </p>
                <p class="mt-4 text-muted-foreground">
                    Last updated: April 12, 2026
                </p>
            </section>

            <section id="acceptance-of-terms" class="mt-12">
                <h2 class="text-xl">Acceptance of Terms</h2>
                <p class="mt-2 text-muted-foreground">By accessing or using any Veblex service — including Veblex Gym, Calendar, and Auth — you agree to be bound by these terms. If you do not agree, you may not use the services.</p>
            </section>

            <section id="account-responsibilities" class="mt-12">
                <h2 class="text-xl">Account Responsibilities</h2>
                <p class="mt-2 text-muted-foreground">You are responsible for maintaining the security of your Veblex account credentials and for all activities that occur under your account across the ecosystem.</p>
            </section>

            <section id="acceptable-use" class="mt-12">
                <h2 class="text-xl">Acceptable Use</h2>
                <p class="mt-2 text-muted-foreground">You agree not to misuse Veblex services, including attempting to access systems without authorization, interfering with service operations, or violating applicable laws.</p>
            </section>

            <section id="intellectual-property" class="mt-12">
                <h2 class="text-xl">Intellectual Property</h2>
                <p class="mt-2 text-muted-foreground">All content, trademarks, and technology within the Veblex ecosystem are owned by Veblex. You may not reproduce or distribute any materials without written permission.</p>
            </section>

            <section id="limitation-of-liability" class="mt-12">
                <h2 class="text-xl">Limitation of Liability</h2>
                <p class="mt-2 text-muted-foreground">Veblex services are provided 'as is.' To the maximum extent permitted by law, Veblex shall not be liable for indirect, incidental, or consequential damages.</p>
            </section>

            <section id="modifications" class="mt-12">
                <h2 class="text-xl">Modifications</h2>
                <p class="mt-2 text-muted-foreground">We reserve the right to update these terms. Continued use of Veblex services after changes constitutes acceptance of the revised terms.</p>
            </section>
        </article>
    </main>
</Layout>
