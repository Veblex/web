---
import Layout from "@layouts/root.astro";
import { ArrowRight, Cookie, FileText, Shield } from "@lucide/astro";
import { cn } from "@workspace/ui/lib/utils";

const legalPages = [
    {
        icon: Shield,
        title: "Privacy Policy",
        description:
            "Learn how Veblex collects, uses, and protects your personal data across all ecosystem services.",
        href: "/legal/privacy",
        featured: false,
    },
    {
        icon: FileText,
        title: "Terms of Service",
        description:
            "Review the terms and conditions governing your use of the Veblex ecosystem and all its products.",
        href: "/legal/terms",
        featured: true,
    },
    {
        icon: Cookie,
        title: "Cookie Policy",
        description:
            "Understand how Veblex uses cookies and similar technologies to enhance your browsing experience.",
        href: "/legal/cookies",
        featured: false,
    },
];
---

<Layout page="Legal" title="Legal - Veblex Privacy, Terms & Cookies" description="Review Veblex legal policies: Privacy Policy, Terms of Service, and Cookie Policy. Transparency across the Veblex ecosystem.">
    <main class="flex-1">
        <section
            class="mx-auto container px-4 py-8 sm:px-6 lg:px-8 mt-16 space-y-20"
        >
            <div class="mx-auto max-w-2xl">
                <h1 class="my-4 text-4xl font-bold tracking-tight">
                    Legal & Policies
                </h1>

                <p class="text-lg text-muted-foreground">
                    Transparency matters. Review the policies that govern the
                    Veblex ecosystem and how we protect your rights.
                </p>
            </div>

            <div class="grid md:grid-cols-2 xl:grid-cols-3 gap-6">
                {
                    legalPages.map((page) => (
                        <a
                            href={page.href}
                            class={cn(
                                "group cursor-pointer flex flex-col bg-card rounded-lg border border-primary/30 p-6 space-y-2 transition-all duration-300 hover:border-primary/50 hover:scale-[1.02]",
                                page.featured
                                    ? "md:row-span-2 xl:row-span-1"
                                    : "",
                            )}
                        >
                            <h2 class="text-2xl font-bold tracking-tight">
                                {page.title}
                            </h2>

                            <p class="text-muted-foreground flex-1">
                                {page.description}
                            </p>

                            <span class="mt-auto pt-6 flex gap-1 items-center transition-all duration-300 group-hover:ml-1.5">
                                Read more <ArrowRight class="size-5" />
                            </span>
                        </a>
                    ))
                }
            </div>
        </section>
    </main>
</Layout>
