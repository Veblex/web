---
import { cn } from "@workspace/ui/lib/utils"
import { Menu, X } from "@lucide/astro"
import { FullDark, FullLight } from "@workspace/ui/brand-icons"

// Mock auth state - in a real app this would come from Veblex Auth
const mockUser = null // Set to { name: "John Doe", email: "john@example.com", avatar: "" } to test logged in state
const user = mockUser

const pathname = new URL(Astro.request.url).pathname

const isCurrentPage = (page: string) => {
    if (page === "home") return pathname === "/"
    return pathname.startsWith(`/${page}`)
}
---

<header
    class="sticky top-0 z-50 w-full bg-background/95 backdrop-blur supports-backdrop-filter:bg-background/60"
>
    <div
        class="container mx-auto flex h-16 items-center justify-between gap-4 px-4 sm:px-6 lg:px-8"
    >
        <a href="/" class="flex w-26">
            <FullLight className="not-dark:hidden" />
            <FullDark className="dark:hidden" />
        </a>

        <div class="flex items-center gap-4">
            <!-- Desktop nav -->
            <nav class="hidden items-center gap-1 justify-self-center md:flex">
                <a
                    href="/services"
                    class={cn(
                        "flex px-4 py-2 text-muted-foreground hover:text-foreground",
                        isCurrentPage("services") && "text-foreground"
                    )}>Services</a
                >
                <a
                    href="/about"
                    class={cn(
                        "flex px-4 py-2 text-muted-foreground hover:text-foreground",
                        isCurrentPage("about") && "text-foreground"
                    )}>About</a
                >
            </nav>

            <!-- Auth buttons / profile -->
            <div class="ml-auto flex items-center gap-4 justify-self-end">
                <div class="hidden items-center gap-2 md:flex">
                    <a
                        href="https://auth.veblex.com/"
                        class="flex items-center justify-between gap-2 rounded-lg bg-primary px-4 py-2 font-medium text-primary-foreground hover:bg-primary/90"
                    >
                        Create Account
                    </a>
                </div>
            </div>

            <!-- Mobile menu button -->
            <button
                class="cursor-pointer justify-self-end rounded-md md:hidden"
                id="menu-button"
            >
                <Menu id="menu-icon" class="size-5" />
                <X id="close-icon" class="hidden size-5" />
                <span class="sr-only">Toggle menu</span>
            </button>
        </div>
    </div>

    <div
        id="mobile-menu"
        class="absolute top-full right-0 left-0 z-50 hidden border-y border-border bg-background/95 backdrop-blur-lg md:hidden"
    >
        <nav class="flex flex-col gap-4 p-4">
            <a
                href="/services"
                class="rounded-md px-4 py-2 text-muted-foreground transition-colors hover:bg-secondary hover:text-foreground"
            >
                Services
            </a>
            <a
                href="/about"
                class="rounded-md px-4 py-2 text-muted-foreground transition-colors hover:bg-secondary hover:text-foreground"
            >
                About
            </a>
            <div class="flex flex-col gap-2 pt-2">
                <a
                    href="https://auth.veblex.com/"
                    class="flex items-center justify-between gap-2 rounded-lg bg-primary px-4 py-2 font-medium text-primary-foreground hover:bg-primary/90"
                >
                    Create Account
                </a>
            </div>
        </nav>
    </div>
</header>

<script>
    const setupMenu = () => {
        const button = document.getElementById("menu-button")
        const menu = document.getElementById("mobile-menu")
        const menuIcon = document.getElementById("menu-icon")
        const closeIcon = document.getElementById("close-icon")

        if (button && menu) {
            const mobile_links = menu.querySelectorAll(
                'a[href="#services"], a[href="#mission"], a[href="#contact"]'
            )

            mobile_links.forEach((link) => {
                link.addEventListener("click", () => {
                    menu.classList.add("hidden")

                    if (!menuIcon || !closeIcon) {
                        return
                    }

                    menuIcon.classList.remove("hidden")
                    closeIcon.classList.add("hidden")
                })
            })

            button.addEventListener("click", () => {
                menu.classList.toggle("hidden")

                if (!menuIcon || !closeIcon) {
                    return
                }

                menuIcon.classList.toggle("hidden")
                closeIcon.classList.toggle("hidden")
            })
        }
    }

    setupMenu()
    document.addEventListener("astro:after-swap", setupMenu)
</script>
